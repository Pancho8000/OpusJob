        <mxCell id="5" value="<div style=&quot;font-size:14px&quot;><b>candidates</b></div><div style=&quot;font-size:12px&quot;>PK id INT(11) NN AI&lt;br/&gt;name VARCHAR(255) NN&lt;br/&gt;profession VARCHAR(255) NN&lt;br/&gt;location VARCHAR(255) NN&lt;br/&gt;salary_expectation VARCHAR(100) NN&lt;br/&gt;skills VARCHAR(255) NN&lt;br/&gt;bio TEXT NULL&lt;br/&gt;image VARCHAR(255) NULL&lt;br/&gt;created_at DATETIME NULL DEFAULT CURRENT_TIMESTAMP&lt;br/&gt;email VARCHAR(255) NULL&lt;br/&gt;phone VARCHAR(50) NULL&lt;br/&gt;cv_url VARCHAR(255) NULL&lt;br/&gt;years_experience INT(11) NN DEFAULT 0</div>" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#94a3b8;fontColor=#e2e8f0;align=left;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
