  <diagram id="erd-opusjob" name="ERD (Crow's Foot)">
    <mxGraphModel dx="1434" dy="832" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="<div style=&quot;font-size:14px&quot;><b>users</b></div><div style=&quot;font-size:12px&quot;>PK id INT(11) NN AI&lt;br/&gt;name VARCHAR(255) NN&lt;br/&gt;email VARCHAR(255) NN&lt;br/&gt;location VARCHAR(255) NULL DEFAULT 'Santiago'&lt;br/&gt;avatar VARCHAR(255) NULL&lt;br/&gt;password VARCHAR(255) NN&lt;br/&gt;role ENUM('user','recruiter') NULL DEFAULT 'user'&lt;br/&gt;created_at DATETIME NULL DEFAULT CURRENT_TIMESTAMP</div>" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#94a3b8;fontColor=#e2e8f0;align=left;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="60" width="430" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="<div style=&quot;font-size:14px&quot;><b>jobs</b></div><div style=&quot;font-size:12px&quot;>PK id INT(11) NN AI&lt;br/&gt;title VARCHAR(255) NN&lt;br/&gt;image VARCHAR(255) NULL DEFAULT 'default.jpg'&lt;br/&gt;company VARCHAR(255) NN&lt;br/&gt;location VARCHAR(255) NN&lt;br/&gt;salary VARCHAR(100) NN&lt;br/&gt;type VARCHAR(50) NN&lt;br/&gt;description TEXT NULL&lt;br/&gt;created_at DATETIME NULL DEFAULT CURRENT_TIMESTAMP&lt;br/&gt;status ENUM('draft','published') NULL DEFAULT 'published'&lt;br/&gt;requirements_tech TEXT NULL&lt;br/&gt;requirements_soft TEXT NULL&lt;br/&gt;benefits TEXT NULL&lt;br/&gt;deadline DATE NULL&lt;br/&gt;FK recruiter_id INT(11) NULL → users.id&lt;br/&gt;updated_at DATETIME NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP</div>" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#94a3b8;fontColor=#e2e8f0;align=left;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="40" width="520" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="<div style=&quot;font-size:14px&quot;><b>job_likes</b> (postulaciones)</div><div style=&quot;font-size:12px&quot;>PK id INT(11) NN AI&lt;br/&gt;FK user_id INT(11) NN → users.id&lt;br/&gt;FK job_id INT(11) NN → jobs.id&lt;br/&gt;created_at DATETIME NULL DEFAULT CURRENT_TIMESTAMP&lt;br/&gt;status VARCHAR(32) NN DEFAULT 'postulacion_recibida'&lt;br/&gt;updated_at DATETIME NULL&lt;br/&gt;UQ (user_id, job_id)</div>" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#94a3b8;fontColor=#e2e8f0;align=left;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
